# Middleware password gate (optional) — leave unset to disable
SITE_PASSWORD=

# Supabase — copy to .env.local and fill in from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Import script only (scripts/import-canon.ts) — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# One-time migration (scripts/apply-migration.ts) — Project Settings → Database
# SUPABASE_DB_PASSWORD=your-database-password
# Or: DATABASE_URL=postgresql://postgres:...@db.<ref>.supabase.co:5432/postgres
